{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "baseUrl": ".",
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedDeclarations": false,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "DOM.AsyncIterable", "ES2023"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "paths": {
      "@durable-streams/client": ["packages/client/src/index.ts"],
      "@durable-streams/client/*": ["packages/client/src/*"],
      "@durable-streams/state": ["packages/state/src/index.ts"],
      "@durable-streams/state/*": ["packages/state/src/*"],
      "@durable-streams/server": ["packages/server/src/index.ts"],
      "@durable-streams/server/*": ["packages/server/src/*"],
      "@durable-streams/ts-darix-server": [
        "packages/ts-darix-server/src/index.ts"
      ],
      "@durable-streams/ts-darix-server/*": ["packages/ts-darix-server/src/*"],
      "@durable-streams/server-conformance-tests": [
        "packages/server-conformance-tests/src/index.ts"
      ],
      "@durable-streams/server-conformance-tests/*": [
        "packages/server-conformance-tests/src/*"
      ],
      "@durable-streams/darix-server-conformance-tests": [
        "packages/darix-server-conformance-tests/src/index.ts"
      ],
      "@durable-streams/darix-server-conformance-tests/*": [
        "packages/darix-server-conformance-tests/src/*"
      ],
      "@durable-streams/darix-runtime": [
        "packages/ts-darix-runtime/src/index.ts"
      ],
      "@durable-streams/darix-runtime/*": ["packages/ts-darix-runtime/src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "noErrorTruncation": true
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": [
    "node_modules",
    "**/dist/**",
    "**/build/**",
    "**/*.config.ts",
    "**/test/**",
    "**/*.test.ts",
    "packages/caddy-plugin/**",
    "packages/darix-ui/**",
    "packages/darix-app/**",
    "packages/darix-cli/**",
    "examples/yjs-demo/**"
  ]
}
