{
  "name": "@durable-streams/example-chat-tanstack-forks",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx start-dev.ts",
    "dev:app": "vite dev",
    "dev:streams": "pnpm --filter @durable-streams/cli start:dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "pnpm run preview:cloudflare",
    "preview:cloudflare": "pnpm run build && pnpm exec wrangler dev --config .output/server/wrangler.json",
    "deploy:cloudflare": "pnpm run build && pnpm exec wrangler deploy --config .output/server/wrangler.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@durable-streams/client": "workspace:*",
    "@durable-streams/tanstack-ai-transport": "workspace:*",
    "@tanstack/ai": "latest",
    "@tanstack/ai-openai": "latest",
    "@tanstack/ai-react": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "nitro": "npm:nitro-nightly@latest",
    "tsx": "latest",
    "typescript": "~5.9.3",
    "vite": "latest",
    "vite-tsconfig-paths": "latest",
    "wrangler": "^4.79.0"
  }
}
