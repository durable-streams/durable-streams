    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@durable-streams/client": "workspace:^",
    "@durable-streams/state": "workspace:^",
    "@durable-streams/y-durable-streams": "workspace:^",
    "@tanstack/react-db": "latest",
    "dotenv": "^16.5.0",
    "lib0": "^0.2.117",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "y-protocols": "^1.0.6",
