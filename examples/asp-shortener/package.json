{
  "name": "@durable-streams/example-asp-shortener",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare Worker that creates short URLs for asp (agent-session-protocol) shared sessions",
  "type": "module",
  "scripts": {
    "build:viewer": "pnpm --filter @durable-streams/example-asp-shortener-viewer build",
    "predev": "pnpm build:viewer",
    "predeploy": "pnpm build:viewer",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "~5.9.3",
    "wrangler": "^3.100.0"
  }
}
